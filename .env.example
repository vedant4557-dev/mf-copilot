# .env.example — copy to .env and fill in real values
# Secrets are managed via Doppler in production (doppler run -- node ...)
# Or via AWS Secrets Manager / Parameter Store

# ── Database ──────────────────────────────────────────────────
DB_NAME=mfcopilot
DB_USER=mfcopilot
DB_PASS=change_me_in_production

DATABASE_URL="postgresql://${DB_USER}:${DB_PASS}@localhost:5432/${DB_NAME}?schema=public"
DIRECT_URL="postgresql://${DB_USER}:${DB_PASS}@localhost:5432/${DB_NAME}?schema=public"

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_production
REDIS_URL="redis://:${REDIS_PASSWORD}@localhost:6379"

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET="at_least_32_characters_long_secret_here"
JWT_EXPIRES_IN="7d"

SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIs..."

# ── AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-..."
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ── Payments (Razorpay) ───────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="..."
RAZORPAY_WEBHOOK_SECRET="..."

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@copilot.example.com"

# ── KYC (DigiLocker) ─────────────────────────────────────────
DIGILOCKER_CLIENT_ID="..."
DIGILOCKER_CLIENT_SECRET="..."
DIGILOCKER_REDIRECT_URI="https://copilot.example.com/api/kyc/callback"

# ── Encryption (AWS KMS) ─────────────────────────────────────
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
KMS_KEY_ARN="arn:aws:kms:ap-south-1:123456789:key/..."

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN="https://...@sentry.io/..."
DATADOG_API_KEY="..."
DATADOG_APP_KEY="..."

# ── Product Analytics ─────────────────────────────────────────
MIXPANEL_TOKEN="..."
GA_MEASUREMENT_ID="G-XXXXXXXX"
GA_API_SECRET="..."

# ── CAS Parser service ────────────────────────────────────────
CAS_PARSER_URL="http://cas-parser:5000"

# ── Frontend (Next.js public) ────────────────────────────────
NEXT_PUBLIC_API_URL="https://copilot.example.com/api"
NEXT_PUBLIC_SUPABASE_URL="${SUPABASE_URL}"
NEXT_PUBLIC_SUPABASE_ANON_KEY="${SUPABASE_ANON_KEY}"
NEXT_PUBLIC_RAZORPAY_KEY="${RAZORPAY_KEY_ID}"
NEXT_PUBLIC_GA_ID="${GA_MEASUREMENT_ID}"

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
WEB_ORIGIN="https://copilot.example.com"
LOG_LEVEL="info"
